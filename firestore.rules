// Firestore Security Rules
// Add these rules to your Firebase Console: Firestore → Rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow all users (including unauthenticated) to read and write posts
    // NOTE: Change this to require authentication in production!
    match /posts/{postId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if true;
    }
    
    // Allow users to manage their own profile data
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}

